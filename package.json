    "esbuild": "^0.28.1",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "idb-keyval": "^6.3.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.23.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
